<?xml version="1.0" ?>
<robot name="ros_car">
  <material name="blue"><color rgba="0.2 0.5 0.8 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
  <material name="red"><color rgba="0.8 0.2 0.2 1.0"/></material>

  <link name="base_link">
    <visual><geometry><box size="0.32 0.20 0.08"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/><material name="blue"/></visual>
    <collision><geometry><box size="0.32 0.20 0.08"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="2.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/></inertial>
  </link>

  <link name="laser_support">
    <visual><geometry><cylinder length="0.05" radius="0.02"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/><material name="gray"/></visual>
    <collision><geometry><cylinder length="0.05" radius="0.02"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="laser_support_joint" type="fixed"><parent link="base_link"/><child link="laser_support"/><origin rpy="0 0 0" xyz="0.10 0 0.035"/></joint>

  <link name="laser_link">
    <visual><geometry><cylinder length="0.03" radius="0.04"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/><material name="red"/></visual>
    <collision><geometry><cylinder length="0.03" radius="0.04"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.1"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
  </link>
  <joint name="laser_joint" type="fixed"><parent link="laser_support"/><child link="laser_link"/><origin rpy="0 0 0" xyz="0 0 0.025"/></joint>

  <link name="imu_link">
    <visual><geometry><box size="0.03 0.03 0.01"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/><material name="gray"/></visual>
    <collision><geometry><box size="0.03 0.03 0.01"/></geometry><origin rpy="0 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.02"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
  </link>
  <joint name="imu_joint" type="fixed"><parent link="base_link"/><child link="imu_link"/><origin rpy="0 0 0" xyz="0 0 0"/></joint>

  <link name="left_front_knuckle_link"><inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link>
  <link name="right_front_knuckle_link"><inertial><mass value="0.1"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial></link>

  <joint name="left_front_steer_joint" type="revolute">
    <parent link="base_link"/><child link="left_front_knuckle_link"/>
    <origin xyz="0.085 0.14 -0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7" upper="0.7" effort="100" velocity="1.0"/>
  </joint>
  <joint name="right_front_steer_joint" type="revolute">
    <parent link="base_link"/><child link="right_front_knuckle_link"/>
    <origin xyz="0.085 -0.14 -0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.7" upper="0.7" effort="100" velocity="1.0"/>
  </joint>

  <link name="left_front_link">
    <visual><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/><material name="black"/></visual>
    <collision><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <gazebo reference="left_front_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <link name="right_front_link">
    <visual><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/><material name="black"/></visual>
    <collision><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <gazebo reference="right_front_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <link name="left_rear_link">
    <visual><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/><material name="black"/></visual>
    <collision><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <gazebo reference="left_rear_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <link name="right_rear_link">
    <visual><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/><material name="black"/></visual>
    <collision><geometry><cylinder length="0.04" radius="0.05"/></geometry><origin rpy="1.5708 0 0" xyz="0 0 0"/></collision>
    <inertial><mass value="0.2"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <gazebo reference="right_rear_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <material>Gazebo/Black</material>
  </gazebo>

  <joint name="left_front_roll_joint" type="continuous">
    <parent link="left_front_knuckle_link"/><child link="left_front_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" velocity="2.0"/>
  </joint>
  <joint name="right_front_roll_joint" type="continuous">
    <parent link="right_front_knuckle_link"/><child link="right_front_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" velocity="2.0"/>
  </joint>
  <joint name="left_rear_roll_joint" type="continuous">
    <parent link="base_link"/><child link="left_rear_link"/>
    <origin xyz="-0.085 0.14 -0.075" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" velocity="2.0"/>
  </joint>
  <joint name="right_rear_roll_joint" type="continuous">
    <parent link="base_link"/><child link="right_rear_link"/>
    <origin xyz="-0.085 -0.14 -0.075" rpy="0 0 0"/><axis xyz="0 1 0"/>
    <limit effort="100" velocity="2.0"/>
  </joint>

  <link name="dummy_steering_wheel"/>
  <joint name="dummy_steering_wheel_joint" type="fixed">
    <parent link="base_link"/><child link="dummy_steering_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="laser_link">
    <sensor name="laser" type="ray">
      <always_on>true</always_on><visualize>true</visualize><update_rate>20</update_rate>
      <ray><scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
      <range><min>0.1</min><max>8.0</max><resolution>0.01</resolution></range>
      <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise></ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="gazebo_ros_laser">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type><frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on><update_rate>50</update_rate><visualize>true</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="gazebo_ros_imu">
        <ros><remapping>~/out:=imu</remapping></ros><frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="libgazebo_ros_ackermann_drive.so" name="ackermann_controller">
      <update_rate>50</update_rate>
      <front_left_joint>left_front_roll_joint</front_left_joint>
      <front_right_joint>right_front_roll_joint</front_right_joint>
      <rear_left_joint>left_rear_roll_joint</rear_left_joint>
      <rear_right_joint>right_rear_roll_joint</rear_right_joint>
      <left_steering_joint>left_front_steer_joint</left_steering_joint>
      <right_steering_joint>right_front_steer_joint</right_steering_joint>
      <wheelbase>0.17</wheelbase>
      <track>0.28</track>
      <wheel_radius>0.05</wheel_radius>
      <max_steer>0.7</max_steer>
      <max_steering_angle>1.57</max_steering_angle>
      <max_speed>2.0</max_speed>
      <left_steering_pid_gain>3.0 0.5 0.1</left_steering_pid_gain>
      <left_steering_i_range>-1.0 1.0</left_steering_i_range>
      <right_steering_pid_gain>3.0 0.5 0.1</right_steering_pid_gain>
      <right_steering_i_range>-1.0 1.0</right_steering_i_range>
      <linear_velocity_pid_gain>0.5 0.01 0</linear_velocity_pid_gain>
      <linear_velocity_i_range>-0.5 0.5</linear_velocity_i_range>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <publish_distance>true</publish_distance>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
    <plugin filename="libgazebo_ros_joint_state_publisher.so" name="joint_state_publisher">
      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>50</update_rate>
      <joint_name>left_front_steer_joint</joint_name>
      <joint_name>right_front_steer_joint</joint_name>
      <joint_name>left_front_roll_joint</joint_name>
      <joint_name>right_front_roll_joint</joint_name>
      <joint_name>left_rear_roll_joint</joint_name>
      <joint_name>right_rear_roll_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
